# Copy this to 'config' and fill in your Apple ID.
#   cp config.example config
#
# Credentials are fetched via 'pass' (Linux) or 'security' (macOS).
# See setup.sh output for instructions on storing your passwords.
#
# Note: vdirsyncer only supports password.fetch for credentials.
# The username must be inline — this is why 'config' is gitignored
# and only 'config.example' is tracked.

[general]
# Keep status outside the repo to avoid clutter in the working tree.
# The symlink makes ~/.config/vdirsyncer point into the repo, so
# storing status here would put sync state alongside tracked files.
status_path = "~/.local/share/vdirsyncer/status/"

[pair icloud_contacts]
a = "icloud_local"
b = "icloud_remote"
collections = [["icloud_contacts", "card", "main"]]
# iCloud is the source of truth (managed from Apple devices),
# so remote wins on conflict.
conflict_resolution = "b wins"
metadata = ["displayname"]

[storage icloud_local]
type = "filesystem"
path = "~/.local/share/vdirsyncer/contacts/icloud/"
fileext = ".vcf"

[storage icloud_remote]
type = "carddav"
url = "https://contacts.icloud.com/"
# Replace with your Apple ID email:
username = "YOUR_APPLE_ID@icloud.com"
# Linux (pass):
password.fetch = ["command", "pass", "contacts/icloud-app-password"]
# macOS (keychain) — uncomment and comment out the line above:
# password.fetch = ["command", "security", "find-generic-password", "-s", "vdirsyncer-icloud", "-w"]
