# Copy this to 'config' and fill in your credentials.
#   cp config.example config
#
# iCloud credentials are fetched via 'pass' (Linux) or 'security' (macOS).
# Google Calendar uses OAuth2 — run 'vdirsyncer discover google_calendars'
# to complete the browser-based consent flow (one-time).
#
# See setup.sh output for instructions on storing your passwords.
#
# Note: vdirsyncer only supports password.fetch for credentials.
# The username must be inline — this is why 'config' is gitignored
# and only 'config.example' is tracked.

[general]
# Keep status outside the repo to avoid clutter in the working tree.
# The symlink makes ~/.config/vdirsyncer point into the repo, so
# storing status here would put sync state alongside tracked files.
status_path = "~/.local/share/vdirsyncer/status/"

[pair icloud_contacts]
a = "icloud_local"
b = "icloud_remote"
# Autodiscover collections from both sides so we don't need to
# hardcode iCloud's internal collection names.
collections = ["from a", "from b"]
# iCloud is the source of truth (managed from Apple devices),
# so remote wins on conflict.
conflict_resolution = "b wins"
metadata = ["displayname"]

[storage icloud_local]
type = "filesystem"
path = "~/.local/share/vdirsyncer/contacts/icloud/"
fileext = ".vcf"

[storage icloud_remote]
type = "carddav"
url = "https://contacts.icloud.com/"
# Replace with your Apple ID email:
username = "YOUR_APPLE_ID@icloud.com"
# Linux (pass):
password.fetch = ["command", "pass", "contacts/icloud-app-password"]
# macOS (keychain) — uncomment and comment out the line above:
# password.fetch = ["command", "security", "find-generic-password", "-s", "vdirsyncer-icloud", "-w"]

# ── iCloud Calendar Sync ──────────────────────────

[pair icloud_calendars]
a = "icloud_cal_local"
b = "icloud_cal_remote"
collections = ["from a", "from b"]
conflict_resolution = "b wins"
metadata = ["displayname", "color"]

[storage icloud_cal_local]
type = "filesystem"
path = "~/.local/share/vdirsyncer/calendars/icloud/"
fileext = ".ics"

[storage icloud_cal_remote]
type = "caldav"
url = "https://caldav.icloud.com/"
# Uses the same Apple ID and app password as contacts:
username = "YOUR_APPLE_ID@icloud.com"
# Linux (pass):
password.fetch = ["command", "pass", "contacts/icloud-app-password"]
# macOS (keychain) — uncomment and comment out the line above:
# password.fetch = ["command", "security", "find-generic-password", "-s", "vdirsyncer-icloud", "-w"]

# ── Google Calendar Sync ──────────────────────────
# Requires a Google Cloud OAuth2 client ID + secret.
# Create at: https://console.cloud.google.com/apis/credentials
#   1. Create project (or use existing)
#   2. Enable "Google Calendar API"
#   3. Create OAuth 2.0 Client ID (Desktop app type)
#   4. Copy client_id and client_secret below
#   5. Run: vdirsyncer discover google_calendars
#      (opens browser for one-time OAuth consent)

[pair google_calendars]
a = "google_cal_local"
b = "google_cal_remote"
collections = ["from a", "from b"]
conflict_resolution = "b wins"
metadata = ["displayname", "color"]

[storage google_cal_local]
type = "filesystem"
path = "~/.local/share/vdirsyncer/calendars/google/"
fileext = ".ics"

[storage google_cal_remote]
type = "google_calendar"
token_file = "~/.local/share/vdirsyncer/google_calendar_token"
client_id = "YOUR_GOOGLE_CLIENT_ID"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"
