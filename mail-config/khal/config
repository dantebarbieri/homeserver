[calendars]

[[icloud]]
path = ~/.local/share/vdirsyncer/calendars/icloud/*
type = discover

[[google]]
path = ~/.local/share/vdirsyncer/calendars/google/*
type = discover

[locale]
timeformat = %H:%M
dateformat = %Y-%m-%d
longdateformat = %Y-%m-%d
datetimeformat = %Y-%m-%d %H:%M
longdatetimeformat = %Y-%m-%d %H:%M

[default]
default_calendar = home
