{
  "_comment": "MCP endpoint registry for the OpenClaw agent on the Pi. Two auth shapes are supported per server: legacy `bearer: '...'` shorthand (for the eight servers that still use static-bearer auth via Docker secrets in ${DATA}/mcp/secrets/MCP_TOKEN_<NAME>), and the new `auth: { type: 'oauth_client_credentials', ... }` form (for tcad, which is the first server to expose OAuth 2.1 — Claude.ai uses authorization_code+DCR, OpenClaw uses client_credentials against the same Authelia issuer). OpenClaw must check `auth` first and fall back to `bearer` if absent. The OpenClaw OIDC client_secret comes from ${DATA}/authelia/secrets/openclaw_oidc_secret on the server (shipped here by install-mcp-config.sh). URLs end in /mcp — that's where FastMCP, mcp-proxy, and wikipedia-mcp all serve the streamable-http endpoint by default.",
  "servers": {
    "openzim": {
      "url": "https://mcp.danteb.com/openzim/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_OPENZIM_HERE"
    },
    "wikipedia": {
      "url": "https://mcp.danteb.com/wikipedia/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_WIKIPEDIA_HERE"
    },
    "wikidata-remote": {
      "url": "https://wd-mcp.wmcloud.org/mcp",
      "transport": "streamable-http",
      "bearer": null,
      "note": "Wikimedia Deutschland hosted; primary route for Wikidata queries."
    },
    "wikidata-local": {
      "url": "https://mcp.danteb.com/wikidata/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_WIKIDATA_HERE",
      "note": "Local fallback when wd-mcp.wmcloud.org is unreachable."
    },
    "searxng": {
      "url": "https://mcp.danteb.com/searxng/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_SEARXNG_HERE"
    },
    "nominatim": {
      "url": "https://mcp.danteb.com/nominatim/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_NOMINATIM_HERE"
    },
    "photon": {
      "url": "https://mcp.danteb.com/photon/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_PHOTON_HERE"
    },
    "valhalla": {
      "url": "https://mcp.danteb.com/valhalla/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_VALHALLA_HERE"
    },
    "elev": {
      "url": "https://mcp.danteb.com/elev/mcp",
      "transport": "streamable-http",
      "bearer": "PASTE_MCP_TOKEN_ELEV_HERE"
    },
    "tcad": {
      "url": "https://mcp-tcad.danteb.com/mcp",
      "transport": "streamable-http",
      "auth": {
        "type": "oauth_client_credentials",
        "token_url": "https://authelia.danteb.com/api/oidc/token",
        "client_id": "openclaw-mcp",
        "client_secret": "PASTE_OPENCLAW_OIDC_SECRET_HERE",
        "scope": "mcp:tcad",
        "audience": "https://mcp-tcad.danteb.com"
      },
      "note": "First server using OAuth 2.1 client_credentials; the tcad-mcp server still accepts MCP_TOKEN_TCAD bearer too, so a temporary fallback to `bearer: '...'` here is safe if OAuth setup is incomplete."
    }
  }
}

