# Production config copies — only README.md is tracked (git needs it to track the dir)
production-configs/*
!production-configs/README.md

# Secrets and environment
.env
docker/.env
recyclarr-configs/secrets.yml

# Homepage auto-generated defaults (created on first run)
homepage/custom.css
homepage/custom.js
homepage/kubernetes.yaml
homepage/proxmox.yaml

# Claude Code — track shared config (hooks, skills, settings.json), ignore local
.claude/settings.local.json
