# ==============================================================================
# QUOTING CONVENTION
# Use single quotes for values with special characters — they are literal:
#   GOOD:  MY_KEY='abc!@#123'
#   BAD:   MY_KEY=abc!@#123
# If a value contains a single quote, use double quotes instead:
#   QPASS="hunter'2"
# Inside double quotes, escape only  $ \ " `  with a backslash.
# ==============================================================================

# ==============================================================================
# Common - shared across most services
# ==============================================================================
UID=1000
GID=1000
TZ=America/Chicago
DATA=/srv/docker/data
RAID=/data
# GID of the 'docker' group on the host — needed by containers that mount
# the Docker socket (e.g. Homepage).  Find it with:  getent group docker | cut -d: -f3
DOCKER_GID=999

# ==============================================================================
# External project paths — used by compose files that build from repos outside
# the monorepo. Set these to the absolute paths where each repo is cloned.
# ==============================================================================
HOMEPAGE_CONFIG_PATH=/srv/homeserver/homepage
TRAVEL_PLANNER_PATH=/srv/travel-planner
SKYJO_PATH=/srv/skyjo
SORRY_PATH=/srv/sorry-game
# Absolute path to the monorepo on the host — used by containers that need
# to read the compose files (e.g. vpn-netns-watcher) to run `docker compose`.
REPO_PATH=/srv/homeserver

# ==============================================================================
# Skyjo (card game server)
# ==============================================================================
SKYJO_DB_PASSWORD=''  # Generate with: openssl rand -hex 32 (hex only — no URL-breaking chars)
SKYJO_JWT_SECRET=''   # Generate with: openssl rand -base64 32

# ==============================================================================
# Authelia - secrets are managed as files, not env vars.
# See ${DATA}/authelia/secrets/ and compose.auth.yml for details.
# ==============================================================================

# ==============================================================================
# Immich - https://immich.app/docs/install/environment-variables
# ==============================================================================
UPLOAD_LOCATION=/data/immich
IMMICH_VERSION=release
DB_PASSWORD=''
# Immich internal defaults (rarely need changing)
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
REDIS_HOSTNAME=immich_redis

# ==============================================================================
# Plex
# ==============================================================================
# https://www.plex.tv/claim/
PLEX_CLAIM=claim-xxxxxx
ADVERTISE_IP=http://<hostIPAddress>:32400/

# ==============================================================================
# Gluetun / qBittorrent (VPN + torrents)
# ==============================================================================
WG_PRIVATE_KEY=''
WG_ADDRESS=
SERVER_COUNTRY="United States"
SERVER_CITIES=Austin,Dallas,Houston
QUSER=''
QPASS=''

# ==============================================================================
# wg-easy (WireGuard VPN server)
# ==============================================================================
# Public hostname that VPN clients connect to
WGEASY_HOST=vpn.example.com
# Bcrypt hash for web UI login. Generate with:
#   docker run ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
# IMPORTANT: Single-quote the value — bcrypt hashes contain $ signs
WGEASY_PASSWORD_HASH=''

# ==============================================================================
# Suwayomi (manga reader + Postgres)
# ==============================================================================
SUWAYOMI_USER=suwayomi
SUWAYOMI_PASS=''
SUWAYOMI_DB=suwayomi_db

# ==============================================================================
# Forgejo (self-hosted git)
# ==============================================================================
FORGEJO_DB_PASSWORD=''
# Forgejo LFS — JWT signing secret for Git LFS auth.
# Generate with: openssl rand -base64 32
LFS_JWT_SECRET=''
# Forgejo Actions runner — shared secret for idempotent registration.
# Generate with: openssl rand -hex 20  (must be exactly 40 hex chars)
# After first set, register once on the server with:
#   docker exec forgejo forgejo forgejo-cli actions register \
#       --name homeserver-runner --secret "$FORGEJO_RUNNER_SECRET"
# then paste the printed UUID + this secret into
# ${DATA}/forgejo_runner/runner-config.yml (server.connections.forgejo).
FORGEJO_RUNNER_SECRET=''

# ==============================================================================
# Nextcloud
# ==============================================================================
NEXTCLOUD_HOSTNAME=cloud.example.com
NEXTCLOUD_DB_PASSWORD=''
# Only used on first startup to create the admin account:
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=''

# ==============================================================================
# Matrix / Synapse / LiveKit
# ==============================================================================
SYNAPSE_SERVER_NAME=example.com
SYNAPSE_DB_PASSWORD=''
# Shared secret between Synapse and Coturn for TURN auth.
# Must also be set in turnserver.conf and homeserver.yaml (see MATRIX.md).
COTURN_AUTH_SECRET=''
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=''

# ==============================================================================
# Monitoring (Grafana)
# ==============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=''

# ==============================================================================
# Homepage - service widget API keys/credentials
# Obtain keys from each service's settings page.
# ==============================================================================
HOMEPAGE_ALLOWED_HOSTS=homepage.example.com
HOMEPAGE_VAR_PLEX_TOKEN=''
HOMEPAGE_VAR_JELLYFIN_KEY=''
HOMEPAGE_VAR_SEERR_KEY=''
HOMEPAGE_VAR_IMMICH_KEY=''
HOMEPAGE_VAR_KOMGA_USER=''
HOMEPAGE_VAR_KOMGA_PASS=''
HOMEPAGE_VAR_RADARR_KEY=''
HOMEPAGE_VAR_SONARR_KEY=''
HOMEPAGE_VAR_BAZARR_KEY=''
HOMEPAGE_VAR_PROWLARR_KEY=''
HOMEPAGE_VAR_SABNZBD_KEY=''
HOMEPAGE_VAR_NPM_USER=''
HOMEPAGE_VAR_NPM_PASS=''
HOMEPAGE_VAR_TDARR_KEY=''
HOMEPAGE_VAR_QBIT_USER=''
HOMEPAGE_VAR_QBIT_PASS=''
HOMEPAGE_VAR_NEXTCLOUD_USER=''
HOMEPAGE_VAR_NEXTCLOUD_PASS=''
HOMEPAGE_VAR_ADGUARD_USERNAME=''
HOMEPAGE_VAR_ADGUARD_PASSWORD=''
HOMEPAGE_VAR_KUMA_SLUG=''
HOMEPAGE_VAR_GRAFANA_USER=''
HOMEPAGE_VAR_GRAFANA_PASS=''
HOMEPAGE_VAR_CALIBRE_USER=''
HOMEPAGE_VAR_CALIBRE_PASS=''
HOMEPAGE_VAR_SUWAYOMI_USER=''
HOMEPAGE_VAR_SUWAYOMI_PASS=''
HOMEPAGE_VAR_HARDCORE_MC_IP_OR_DOMAIN=''
HOMEPAGE_VAR_HARDCORE_MC_PORT=25565
HOMEPAGE_VAR_RLCRAFT_MC_IP_OR_DOMAIN=''
HOMEPAGE_VAR_RLCRAFT_MC_PORT=25565
HOMEPAGE_VAR_CHANGEDETECTION_KEY=''

# ==============================================================================
# SearXNG
# ==============================================================================
SEARXNG_HOSTNAME=
SEARXNG_SECRET_KEY=''  # Generate with: openssl rand -hex 32

# ==============================================================================
# Tdarr
# ==============================================================================
TDARR_API_KEY=''

# ==============================================================================
# BMC IP Monitor — NPM credentials for auto-updating IPMI proxy host
# ==============================================================================
NPM_EMAIL=admin@example.com
NPM_PASSWORD=changeme

# ==============================================================================
# CouchDB — backend for the Obsidian "Self-hosted LiveSync" plugin
# (https://github.com/vrtmrz/obsidian-livesync). Exposed via NPM at
# https://couchdb.danteb.com. These are the CouchDB admin credentials; they are
# also the username/password you enter in the LiveSync plugin. See
# docs/OBSIDIAN-LIVESYNC.md for the one-time bootstrap + client setup.
# ==============================================================================
COUCHDB_USER=obsidian
# Generate with: openssl rand -hex 24  (avoid URL-breaking chars — used in the
# LiveSync remote URI / setup wizard)
COUCHDB_PASSWORD=''

# ==============================================================================
# ConvertX - File Format Conversion
# ==============================================================================
CONVERTX_JWT_SECRET=''  # Generate with: openssl rand -base64 32

# ==============================================================================
# Gaming (Minecraft)
# ==============================================================================
CF_API_KEY=''

# Changedetection.io
CHANGEDETECTION_HOSTNAME=cd.danteb.com

# The mcp-tcad bearer token is a file-secret, NOT an env var. It lives at
# ${DATA}/mcp/secrets/MCP_TOKEN_TCAD and is referenced via Docker `secrets:`
# in docker-compose.yml.

# ==============================================================================
# Grocy — household stock / medicine / pantry inventory
# ==============================================================================
# API key for the grocy-ntfy sidecar. Generate from Grocy:
#   Settings (gear icon) → Manage API keys → Add → name it 'homeserver-ntfy'
# Leave blank until you've logged in once and created the key.
GROCY_API_KEY=''
# ntfy topic that receives low-stock alerts. Subscribe to it on your phones
# via the ntfy app. Defaults shown below — change topic if you want a
# separate stream from the system 'homeserver-alerts' topic.
GROCY_NTFY_URL=https://ntfy.danteb.com
GROCY_NTFY_TOPIC=grocy-alerts
# Poll interval in seconds (default 3600 = hourly). Don't go below 60.
GROCY_POLL_INTERVAL=3600

# ==============================================================================
# Grocy auto-consume sidecar — daily scheduled consume for products in the
# named product group. Wakes once a day at GROCY_AUTOCONSUME_TIME (local TZ),
# decrements each tagged product by its `quick_consume_amount`. Combine with
# Grocy's per-product min-stock + the grocy-ntfy bridge for end-to-end
# "set it and forget it" daily medication management.
# ==============================================================================
# Product group name in Grocy whose members should be auto-consumed.
# Create this group via: Manage master data → Product groups → Add.
GROCY_AUTOCONSUME_GROUP=Auto-consume daily
# Local time of day to fire, HH:MM, 24-hour. Uses the container's $TZ.
GROCY_AUTOCONSUME_TIME=08:00
# Set to 1 to receive a low-priority ntfy digest after each successful run.
# Errors always alert at high priority regardless of this setting.
GROCY_AUTOCONSUME_DIGEST=0

